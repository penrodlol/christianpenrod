---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { buttonVariants } from './button.astro';
import Icon from './icon.astro';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  VariantProps<typeof chipVariants> & { value?: string; icon?: string | undefined };

export const chipVariants = tv({
  base: [
    'inline-flex items-center justify-center gap-1 whitespace-nowrap rounded-full',
    'text-[12px] font-semibold h-6 px-2 select-none cursor-default',
  ],
  defaultVariants: { variant: 'solid' },
  variants: { variant: buttonVariants.variants.variant },
});

const { as: Tag = 'button', class: className, variant, value, icon, ...props } = Astro.props;
---

<Tag {...props} class={chipVariants({ variant, className })}>
  {value}
  {icon && <Icon name={icon} class="size-3" />}
</Tag>
