---
import Text from '@/components/ui/text.astro';
import Layout from '@/layouts/index.astro';
import type { GetStaticPaths } from 'astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'posts'>;
type Props = { post: Post; prev: Post; next: Post };

export const getStaticPaths: GetStaticPaths = async () =>
  getCollection('posts').then((posts) =>
    posts
      .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
      .map((post, index, _posts) => {
        const prev = _posts[index + 1] ?? _posts[0];
        const next = _posts[index - 1] ?? _posts[_posts.length - 1];
        return { params: { id: post.id }, props: { post, prev, next } };
      }),
  );

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} og={`open-graph/src/content/posts/${post.id}.png`}>
  <article data-pagefind-body data-pagefind-meta={`slug:/blog/${post.id}`}>
    <Text as="h1" data-pagefind-meta="title">{post.data.title}</Text>
    <Content />
  </article>
</Layout>
