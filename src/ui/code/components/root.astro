---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';

type Props = HTMLAttributes<'figure'>;

const { class: className, ...props } = Astro.props;
---

<figure
  {...props}
  class={twMerge(
    'bg-code-background border-gray-6 relative rounded-sm border',
    '**:data-line:before:mr-2 **:data-line:before:content-[counter(line)]',
    '**:data-line:before:inline-block **:data-line:before:[counter-increment:line]',
    '**:data-line:before:w-5 **:data-line:before:text-current/30',
    '**:data-highlighted-line:*:opacity-30',
    className,
  )}
>
  <slot />
</figure>
