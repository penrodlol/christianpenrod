---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';
import Icon from './icon.astro';

type Props = HTMLAttributes<'aside'>;

const { class: className, id = crypto.randomUUID(), ...props } = Astro.props;
---

<aside
  {...props}
  aria-labelledby={id}
  class={twMerge(
    'bg-accent-2 text-accent-11 flex items-start gap-2 rounded-sm px-4 py-2.5 tracking-wide **:text-xs/6',
    'border-accent-6 border border-l-8 leading-normal',
    className,
  )}
>
  <p {id} aria-label="Note" aria-hidden><Icon name="info" class="text-accent-11 translate-y-1" /></p>
  <section><slot /></section>
</aside>
