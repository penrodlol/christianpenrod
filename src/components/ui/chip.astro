---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './icon.astro';

type Props = HTMLAttributes<'button'> & VariantProps<typeof chipVariants> & { value?: string; icon?: string };

export const chipVariants = tv({
  base: 'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full text-xs py-1 px-2',
  defaultVariants: { variant: 'solid' },
  variants: {
    variant: {
      solid: 'bg-accent-9 text-accent-contrast',
      soft: 'bg-accent-3 text-accent-11',
      'soft-outline': 'bg-accent-3 text-gray-11 border border-accent-7',
      outline: 'bg-transparent text-accent-11 border border-accent-7',
      ghost: 'bg-transparent text-accent-11',
    },
  },
});

const { class: className, variant, value, icon, ...props } = Astro.props;
---

<div {...props} class={chipVariants({ variant, className })}>{icon && <Icon name={icon} class="size-3" />}{value}</div>
