---
import Layout from '@/layouts/index.astro';
import Button from '@/ui/button.astro';
import * as Card from '@/ui/card';
import Chip from '@/ui/chip.astro';
import Command from '@/ui/command.astro';
import Date from '@/ui/date.astro';
import * as Dialog from '@/ui/dialog';
import Icon from '@/ui/icon.astro';
import Input from '@/ui/input.astro';
import Link from '@/ui/link.astro';
import * as List from '@/ui/list';
import Number from '@/ui/number.astro';
import * as Paginator from '@/ui/paginator';
import Separator from '@/ui/separator.astro';
import Text from '@/ui/text.astro';
import type { Page } from 'astro';
import { z } from 'astro/zod';
import { PostView, db, sum } from 'astro:db';
import { PAGEFIND_LINK } from 'astro:env/server';
import { getAllTopics, getSortedPosts, type GetAllTopics, type GetSortedPosts } from './_utils';

type Props = Page<GetSortedPosts[0]> & { topic?: GetAllTopics[0]['id'] };

const posts = await getSortedPosts();
const topics = await getAllTopics();
const readindTime = posts.reduce((a, p) => a + z.coerce.number().parse(p.data.readingTime.replace(/\D/g, '')), 0);
const wordCount = posts.reduce((a, p) => a + (p.body?.split(/\s+/).length ?? 0), 0);
const [{ views } = {}] = await db.select({ views: sum(PostView.views) }).from(PostView);

const { data: activePosts, topic: activeTopic, url, currentPage, lastPage } = Astro.props;
---

<Layout title="Blog | Christian Penrod">
  <section>
    <Text as="h1" size="7" weight="semibold">BLOG POSTS</Text>
    <Text as="h2" size="2" class="mb-20">Explore various sofware-related posts.</Text>
  </section>
  <div x-data="pagefind" class="grid grid-cols-[1fr_35%] gap-20">
    <section class="flex flex-col gap-10">
      <div class="flex items-center gap-1">
        <Text as="h3" size="3">ALL POSTS</Text>
        <Separator class="mx-2 flex-1" />
        <div class="text-gray-11 flex items-center gap-1">
          <div class="flex items-center gap-1">
            <Icon name="eye" />
            <Number size="1" value={z.coerce.number().parse(views)} />
          </div>
          <Icon name="dot" />
          <div class="flex items-center gap-1">
            <Icon name="clock-2" />
            <Text size="1">{(readindTime / 60).toFixed(1)} Hrs</Text>
          </div>
          <Icon name="dot" />
          <div class="flex items-center gap-1">
            <Icon name="notebook-text" />
            <Number size="1" value={wordCount} />
            <Text size="1"> Words</Text>
          </div>
        </div>
      </div>
      <div class="border-gray-6 flex flex-col gap-6 rounded-sm border p-6">
        <Dialog.Root @close="data = []; $refs.query.value = ''">
          <Button slot="dialog-trigger" variant="soft-outline" class="w-full justify-start gap-4">
            <Icon name="search" />
            <Text>Search Posts</Text>
            <Command key="/" class="ml-auto" />
          </Button>
          <Dialog.Header>
            <Input
              x-ref="query"
              class="w-full"
              placeholder="Search posts..."
              autocorrect="off"
              autocapitalize="off"
              @keyup="data = await Promise.all((await search($event.target.value)).results.map((item) => item.data()))"
            >
              <Icon slot="prefix" name="search" />
              <Button
                slot="suffix"
                size="icon"
                variant="ghost"
                icon="x"
                aria-label="Reset"
                @click="$dispatch('close')"
              />
            </Input>
          </Dialog.Header>
          <Dialog.Body>
            <div x-cloak>
              <Text x-show="!data.length && $refs.query.value.length">No Results Found</Text>
              <List.Root
                class:list={[
                  '[&_mark]:border-accent-9 [&_mark]:rounded-sm [&_mark]:border [&_mark]:border-dotted',
                  '[&_mark]:text-gray-12 [&_mark]:bg-transparent [&_mark]:p-0.5',
                ]}
              >
                <template x-for="post in data">
                  <List.ItemLink
                    :href="post.meta.slug"
                    :aria-label="post.meta.title"
                    class="border-gray-6 flex max-w-none flex-col items-start gap-1 rounded-b-none border-b p-6"
                  >
                    <Text weight="semibold" x-text="post.meta.title" class="text-gray-12" />
                    <Text size="1" x-html="post.excerpt + '...'" class="text-gray-11 max-w-none leading-8" />
                  </List.ItemLink>
                </template>
              </List.Root>
            </div>
          </Dialog.Body>
          <Dialog.Footer>
            <div class="text-gray-11 flex items-center gap-2">
              <Command icon="corner-down-left" aria-label="Enter key" />
              <Text size="1">to select</Text>
            </div>
            <div class="text-gray-11 flex items-center gap-1">
              <Command icon="move-down" aria-label="Arrow up key" />
              <Command icon="move-up" aria-label="Arrow down key" />
              <Text size="1" class="ml-1">to navigate</Text>
            </div>
            <div class="text-gray-11 flex items-center gap-2">
              <Command key="esc" aria-label="Escape key" />
              <Text size="1">to close</Text>
            </div>
            <div class="ml-auto flex items-center gap-2">
              <Text size="1">Search by</Text>
              <Link href={PAGEFIND_LINK} iconInternal icon="pagefind" aria-label="Pagefind" class="[&_svg]:size-auto" />
            </div>
          </Dialog.Footer>
        </Dialog.Root>
        <div class="flex flex-wrap gap-2">
          {
            topics.map(({ id, value }) => (
              <Chip
                {value}
                as="a"
                href={id === activeTopic ? '/blog/1' : `/blog/${id}/1`}
                variant={id === activeTopic ? 'solid' : 'soft'}
                icon={id === activeTopic ? 'x' : undefined}
                transition:name={`chip-${value}`}
              />
            ))
          }
        </div>
      </div>
      <div class="flex flex-col gap-6">
        <List.Root>
          {
            activePosts.map((post) => (
              <List.ItemLink href={`/blog/${post.id}`} class="flex max-w-none items-center justify-between gap-2">
                <Text size="1">{post.data.title}</Text>
                <Separator class="flex-1" />
                <div class="text-gray-11 flex items-center gap-1">
                  <Date value={post.data.published} size="1" />
                  <Icon name="dot" />
                  <Text size="1">{post.data.readingTime}</Text>
                </div>
              </List.ItemLink>
            ))
          }
        </List.Root>
        <Paginator.Root class="justify-self-end">
          <Paginator.Start href={url.first} disabled={!url.first} />
          <Paginator.Previous href={url.prev} disabled={!url.prev} />
          <Paginator.Page size="1" current={currentPage} max={lastPage} />
          <Paginator.Next href={url.next} disabled={!url.next} />
          <Paginator.End href={url.last} disabled={!url.last} />
        </Paginator.Root>
      </div>
    </section>
    <section class="flex flex-col gap-6">
      <div class="flex items-center gap-2">
        <Icon name="notebook-pen" class="text-gray-11 size-5 -translate-y-0.5" />
        <Text as="h3" size="3" weight="semibold">RECENT POSTS</Text>
      </div>
      <List.Root class="gap-8">
        {
          posts
            .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
            .slice(0, 3)
            .map((post) => (
              <List.Item>
                <Card.Root as="a" href={`/blog/${post.id}`}>
                  <Card.Body>
                    <List.Root orientation="horizontal" class="-ml-1 gap-1">
                      {post.data.topics.map((value) => (
                        <List.Item>
                          <Chip {value} variant="soft" />
                        </List.Item>
                      ))}
                    </List.Root>
                    <Card.Title>{post.data.title}</Card.Title>
                    <Card.Description>{post.data.description}</Card.Description>
                  </Card.Body>
                  <Card.Footer>
                    <Date size="1" value={post.data.published} />
                    <Icon name="dot" class="text-gray-11 size-6" />
                    <Text size="1">{post.data.readingTime}</Text>
                    <Icon name="dot" class="text-gray-11 size-6" />
                    <Text size="1">2.3K Views</Text>
                  </Card.Footer>
                </Card.Root>
              </List.Item>
            ))
        }
      </List.Root>
    </section>
  </div>
</Layout>
