---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';
import Icon from '../../icon.astro';

type Props = HTMLAttributes<'div'> & { icon: string };

const { class: className, icon, ...props } = Astro.props;
---

<div {...props} class={twMerge('relative flex h-full flex-col rounded border p-4', className)}>
  <slot />
  <div
    class="absolute bottom-0 right-0 flex size-10 items-center justify-center rounded-tl-lg border-l border-t bg-gray-2/50"
  >
    <Icon name={icon} class="text-gray-11" />
  </div>
</div>
