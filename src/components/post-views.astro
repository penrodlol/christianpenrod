---
export const prerender = false;

import Badge from '@/components/ui/badge.astro';
import Text from '@/components/ui/text.astro';
import type { CollectionEntry } from 'astro:content';
import { PostView, db, eq, sql } from 'astro:db';
import { Eye } from 'lucide-astro';

type Props = { slug: CollectionEntry<'posts'>['slug'] };

const views = await db
  .update(PostView)
  .set({ views: sql`${PostView.views} + 1` })
  .where(eq(PostView.post, Astro.props.slug))
  .returning({ views: PostView.views })
  .get()
  .then((res) => res.views.toString().padStart(6, '0'));
---

<Badge><Eye aria-hidden /><Text>{views}</Text> </Badge>
