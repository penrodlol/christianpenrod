---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';
import type { VariantProps } from 'tailwind-variants';
import Arrow from './arrow.astro';
import Icon from './icon.astro';
import Text, { textVariants } from './text.astro';

type Props = HTMLAttributes<'a'> & VariantProps<typeof textVariants> & { icon?: string; iconInternal?: boolean };

const { class: className, href, target, weight, icon, iconInternal, ...props } = Astro.props;
const external = href?.toString().startsWith('https://');
---

<Text
  {...props}
  as="a"
  href={href}
  target={external ? '_blank' : target}
  weight={weight ?? 'semibold'}
  class={twMerge([
    'group text-accent-11 inline-flex items-center justify-center rounded-sm motion-safe:transition-colors',
    'focus-visible:ring-accent-8 focus-visible:ring-2 focus-visible:outline-none',
    external && 'italic',
    className,
  ])}
>
  {icon ? <Icon name={icon} internal={iconInternal ?? false} /> : <slot />}
  {external && !icon && <Arrow name="up-right" />}
</Text>
