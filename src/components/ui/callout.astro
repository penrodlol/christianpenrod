---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';
import Icon from './icon.astro';

type Props = HTMLAttributes<'aside'>;

const { class: className, id = crypto.randomUUID(), ...props } = Astro.props;
---

<aside
  {...props}
  aria-labelledby={id}
  class={twMerge(
    'flex items-start gap-2 rounded bg-accent-2 px-4 py-2.5 text-accent-11',
    'border border-l-8 border-accent-6 leading-normal',
    className,
  )}
>
  <p {id} aria-label="Note" aria-hidden><Icon name="info" class="translate-y-1 text-accent-11" /></p>
  <section><slot /></section>
</aside>
