---
import Clipboard from '@/ui/clipboard.astro';
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'pre'>;

const { class: className, tabindex, ...props } = Astro.props;
---

<Clipboard class="absolute top-0.5 right-1" value="$el.nextElementSibling.textContent.trim()" />
<pre {...props} class="scrollbar overflow-auto rounded-sm p-4"><slot /></pre>
