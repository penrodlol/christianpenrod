---
import Icon from '@/ui/icon.astro';
import Text from '@/ui/text.astro';
import type { CollectionEntry } from 'astro:content';

type Props = { repo: NonNullable<CollectionEntry<'posts'>['data']['repo']> };

const { repo } = Astro.props;
---

<a
  href={repo.websiteUrl}
  target="_blank"
  aria-label={`Check out the github repo: ${repo.name}. ${repo.description}`}
  class="border-gray-6 text-gray-11 bg-gray-2/50 rounded-sm border p-4"
>
  <div class="flex items-center gap-2">
    <Icon name="book" />
    <Text class="text-gray-12">{repo.name}</Text>
  </div>
  <Text size="1" class="mt-2 mb-4">{repo.description}</Text>
  <div class="flex items-center gap-4">
    <div class="flex items-center gap-1">
      <div class="bg-accent-3 border-gray-6 size-4 rounded-full border"></div>
      <Text size="1">{repo.language}</Text>
    </div>
    <div class="flex items-center gap-1">
      <Icon name="star" />
      <Text size="1">{repo.stargazers}</Text>
    </div>
    <div class="flex items-center gap-1">
      <Icon name="git-fork" />
      <Text size="1">{repo.forks}</Text>
    </div>
  </div>
</a>
