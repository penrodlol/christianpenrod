---
import type { HTMLAttributes } from 'astro/types';
import { twMerge } from 'tailwind-merge';

type Props = HTMLAttributes<'figcaption'>;

const { class: className, ...props } = Astro.props;
---

<figcaption {...props} class={twMerge('rounded-t border-b bg-gray-2 px-4 py-1 text-xs text-gray-11', className)}>
  <slot />
</figcaption>
