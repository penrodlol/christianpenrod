---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import Icon from './icon.astro';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  VariantProps<typeof chipVariants> & { value?: string; icon?: string };

export const chipVariants = tv({
  base: 'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full text-[12px] py-px px-2',
  defaultVariants: { variant: 'solid' },
  variants: {
    variant: {
      solid: 'bg-accent-9 text-accent-contrast border border-accent-9',
      soft: 'bg-accent-3 text-accent-11 border border-accent-3',
      'soft-outline': 'bg-accent-3 text-gray-11 border border-accent-7',
      outline: 'bg-transparent text-accent-11 border border-accent-7',
      ghost: 'bg-transparent text-accent-11 border border-transparent',
    },
  },
});

const { as: Tag = 'button', class: className, variant, value, icon, ...props } = Astro.props;
---

<Tag {...props} class={chipVariants({ variant, className })}>
  {icon && <Icon name={icon} class="size-3" />}
  {value}
</Tag>
